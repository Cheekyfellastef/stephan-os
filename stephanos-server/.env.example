PORT=8787
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4

# Keep FRONTEND_ORIGIN for backwards compatibility (single value)
FRONTEND_ORIGIN=http://localhost:5173

# Preferred: comma-separated allowlist of frontend origins
FRONTEND_ORIGINS=http://localhost:5173,https://your-pages-domain

REQUEST_TIMEOUT_MS=30000
