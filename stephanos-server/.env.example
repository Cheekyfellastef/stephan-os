PORT=8787
REQUEST_TIMEOUT_MS=30000

# Keep FRONTEND_ORIGIN for backwards compatibility (single value)
FRONTEND_ORIGIN=http://localhost:5173

# Preferred: comma-separated allowlist of frontend origins
FRONTEND_ORIGINS=http://localhost:5173,https://your-pages-domain

# Optional free-tier providers
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional local provider
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b

# Optional paid provider (disabled by default in UI)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-20b
